# =============================================================================
# LiveKit Server Connection
# =============================================================================

# For local server (docker-compose in repo root):
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# For LiveKit Cloud:
# LIVEKIT_URL=wss://your-project.livekit.cloud
# LIVEKIT_API_KEY=your_cloud_api_key
# LIVEKIT_API_SECRET=your_cloud_api_secret

# =============================================================================
# Pipeline Selection
# =============================================================================

# Set to "true" for local pipeline (FasterWhisper/Ollama/Piper)
# Set to "false" for cloud pipeline (Deepgram/OpenAI/Cartesia)
USE_LOCAL=true

# =============================================================================
# Local Pipeline Configuration (when USE_LOCAL=true)
# =============================================================================

# FasterWhisper STT
WHISPER_MODEL=base                # tiny, base, small, medium, large-v3
WHISPER_DEVICE=cuda               # cuda or cpu

# Piper TTS - Download voices from https://huggingface.co/rhasspy/piper-voices
PIPER_MODEL_PATH=models/piper/en_US-ryan-high.onnx
PIPER_USE_CUDA=false              # CPU recommended due to CUDA version issues

# Ollama LLM - Ensure ollama is running: ollama serve
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434/v1

# =============================================================================
# Cloud Pipeline Configuration (when USE_LOCAL=false)
# =============================================================================

DEEPGRAM_API_KEY=your_deepgram_key
OPENAI_API_KEY=your_openai_key
CARTESIA_API_KEY=your_cartesia_key
